# SparshFolio Email Backend SMTP Settings
# Rename this file to .env.local to configure SMTP mail delivery in production.

# Recipient email address where contact messages are sent
CONTACT_RECEIVER_EMAIL=basedsparshjain@gmail.com

# SMTP Credentials & Configuration (Nodemailer setup)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="SparshFolio Contact" <your-smtp-email@gmail.com>
